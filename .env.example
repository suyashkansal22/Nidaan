# Nidaan environment configuration
# Copy to .env and fill in. Every key is OPTIONAL — with none set the app runs
# fully on a local JSON mock DB with simulated AI + pluggable Workspace.

PORT=5000

# --- Firestore (optional; falls back to server/mock_db.json if absent) ---
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# --- Gemini (optional; orchestrator + triage fall back to heuristics if absent) ---
# Use a Flash model on the free tier so judge traffic doesn't hit the daily cap.
GEMINI_API_KEY=""

# --- Optional Google integrations (left pluggable for the demo) ---
# Set a Maps JS API key to swap the cream SVG radar for a live Google Map.
GOOGLE_MAPS_API_KEY=""
# Set an OAuth token to make Calendar/Gmail/Sheets touchpoints fire for real
# instead of returning labeled "pluggable" simulated successes.
GOOGLE_WORKSPACE_TOKEN=""
